---
// src/components/AnimatedBackground.astro
---

<div class="fixed inset-0 overflow-hidden -z-10 pointer-events-none transition-colors duration-300">
  <!-- Contenedor de las figuras con opacidad baja -->
  <div class="absolute inset-0 opacity-[0.20] dark:opacity-[0.07] text-foreground">
    
    <!-- Figura 1: Microchip (Hardware Embebido) -->
    <svg class="absolute animate-float-slow w-24 h-24 top-[15%] left-[10%]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
      <rect x="9" y="9" width="6" height="6"></rect>
      <line x1="9" y1="1" x2="9" y2="4"></line>
      <line x1="15" y1="1" x2="15" y2="4"></line>
      <line x1="9" y1="20" x2="9" y2="23"></line>
      <line x1="15" y1="20" x2="15" y2="23"></line>
      <line x1="20" y1="9" x2="23" y2="9"></line>
      <line x1="20" y1="14" x2="23" y2="14"></line>
      <line x1="1" y1="9" x2="4" y2="9"></line>
      <line x1="1" y1="14" x2="4" y2="14"></line>
    </svg>

    <!-- Figura 2: Nodos de Red (IA / LLMs) -->
    <svg class="absolute animate-float-medium w-32 h-32 top-[60%] left-[5%]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="18" cy="5" r="3"></circle>
      <circle cx="6" cy="12" r="3"></circle>
      <circle cx="18" cy="19" r="3"></circle>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
    </svg>

    <!-- Figura 3: Código / Corchetes (Software) -->
    <svg class="absolute animate-float-fast w-20 h-20 top-[20%] right-[12%]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="16 18 22 12 16 6"></polyline>
      <polyline points="8 6 2 12 8 18"></polyline>
    </svg>

    <!-- Figura 4: Base de Datos / Servidor -->
    <svg class="absolute animate-float-slow w-28 h-28 top-[65%] right-[8%] delay-700" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
      <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
      <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
    </svg>

  </div>
</div>

<style>
  .animate-float-slow { animation: float 18s ease-in-out infinite; }
  .animate-float-medium { animation: float 14s ease-in-out infinite; animation-delay: -5s; }
  .animate-float-fast { animation: float 10s ease-in-out infinite; animation-delay: -2s; }
  @keyframes float {
    0% { transform: translateY(0px) rotate(0deg); }
    33% { transform: translateY(-20px) rotate(3deg); }
    66% { transform: translateY(15px) rotate(-3deg); }
    100% { transform: translateY(0px) rotate(0deg); }
  }
</style>